dist/

# Run binary artifacts — text metadata (summary/history/log/snapshot) is tracked
runs/**/artifacts/

# plan-003 residual-GRU checkpoints (per fold .pt) — heavy binary, recoverable from configs
runs/baseline/*/ckpt/

# plan-004 P001 PB_0.6822 outputs — heavy intermediates (npz score banks, smoke runs)
runs/baseline/P001_*/oof_*.npz
runs/baseline/P001_*/test_*.npz
runs/baseline/P001_*/smoke/

# Notebooks
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp
.DS_Store

# Local tool artifacts
.playwright-mcp/
.claude/settings.local.json

# Dataset: only the zip is tracked; extracted contents are local-only
data/*
*.zip
!data/open.zip
